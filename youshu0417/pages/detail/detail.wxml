<view class="page">
  <view class="avatar-section">
    <image class="avatar" src="{{user.avatar}}" mode="aspectFill"></image>
    <view class="name-row">
      <text class="name">{{user.nickname}}</text>
      <text class="age">{{user.age}}岁</text>
      <view class="verify-badge" wx:if="{{user.verified}}">实名</view>
    </view>
    <text class="id">编号：{{user.id}}</text>
  </view>

  <view class="info-section">
    <view class="info-title">基本信息</view>
    <view class="info-grid">
      <view class="info-item"><text class="label">地区</text><text class="value">{{user.city}}</text></view>
      <view class="info-item"><text class="label">学历</text><text class="value">{{user.education}}</text></view>
      <view class="info-item"><text class="label">职业</text><text class="value">{{user.job || '未填写'}}</text></view>
      <view class="info-item"><text class="label">身高</text><text class="value">{{user.height}}cm</text></view>
      <view class="info-item"><text class="label">体重</text><text class="value">{{user.weight}}kg</text></view>
      <view class="info-item"><text class="label">资产</text><text class="value">{{user.carLabel}}/{{user.houseLabel}}</text></view>
    </view>
  </view>

  <view class="info-section">
    <view class="info-title">自我介绍</view>
    <text class="requirement-text">{{user.intro || '这个人比较低调，还没有填写自我介绍。'}}</text>
  </view>

  <view class="info-section">
    <view class="info-title">择偶要求</view>
    <text class="requirement-text">{{user.requirementsText || '希望彼此真诚、稳定沟通，有共同生活目标。'}}</text>
  </view>

  <view class="action-bar">
    <button class="btn collect" bindtap="collect">收藏</button>
    <button class="btn contact" open-type="contact">认识一下</button>
  </view>
</view>