.page {
  padding-bottom: 140rpx;
  background: #f3f5f8;
}

.avatar-section {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  padding: 50rpx 30rpx;
  text-align: center;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
}

.name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.name {
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
}

.age {
  font-size: 25rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.24);
  border-radius: 16rpx;
  padding: 4rpx 12rpx;
}

.verify-badge {
  font-size: 22rpx;
  color: #fff;
  background: rgba(45, 195, 106, 0.8);
  border-radius: 12rpx;
  padding: 4rpx 10rpx;
}

.id {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 10rpx;
}

.info-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(19, 33, 68, 0.06);
}

.info-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 33%;
  text-align: center;
  margin-bottom: 16rpx;
}

.label {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.value {
  font-size: 26rpx;
  color: #333;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 24rpx;
  color: #42507a;
  background: #edf2ff;
  border-radius: 18rpx;
  padding: 8rpx 16rpx;
}

.requirement-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #555;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
}

.btn {
  flex: 1;
  border-radius: 42rpx;
}

.collect {
  background: #edf2ff;
  color: #42507a;
}

.contact {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  color: #fff;
}
