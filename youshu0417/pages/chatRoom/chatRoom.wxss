page {
  background: #f5f5f5;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.list {
  flex: 1;
  padding: 24rpx;
}

.footer {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  height: 72rpx;
  background: #f7f8fa;
  border-radius: 36rpx;
  padding: 0 26rpx;
  font-size: 28rpx;
}

.btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin-left: 16rpx;
  border-radius: 36rpx;
  background: #4a90e2;
  color: #fff;
}

.other-row,
.my-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.other-row {
  justify-content: flex-start;
}

.my-row {
  justify-content: flex-end;
}

.avatar-left,
.avatar-right {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.avatar-left {
  margin-right: 16rpx;
}

.avatar-right {
  margin-left: 16rpx;
}

.bubble-left,
.bubble-right {
  max-width: 70%;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  line-height: 1.5;
  font-size: 28rpx;
}

.bubble-left {
  background: #fff;
  color: #333;
}

.bubble-right {
  background: linear-gradient(135deg, #4a90e2, #67b8f5);
  color: #fff;
}
