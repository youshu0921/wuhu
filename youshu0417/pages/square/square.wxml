<view class="page">
  <view class="filter-bar">
    <view class="filter-item {{filter==='same'?'active':''}}" bindtap="setFilter" data-filter="same">同城</view>
    <view class="filter-item {{filter==='all'?'active':''}}" bindtap="setFilter" data-filter="all">全国</view>
  </view>

  <view class="fab" bindtap="showPostModal">+</view>

  <scroll-view scroll-y class="feed-list">
    <view class="empty" wx:if="{{displayPosts.length === 0}}">暂无动态，快来发布吧</view>
    <view class="post-item" wx:for="{{displayPosts}}" wx:key="id">
      <image class="avatar" src="{{item.avatar}}" mode="aspectFill"></image>
      <view class="content">
        <view class="name-row">
          <view>
            <text class="name">{{item.nickname}}</text>
            <text class="city" wx:if="{{item.city}}">{{item.city}}</text>
          </view>
          <text class="time">{{item.time}}</text>
        </view>

        <text class="text">{{item.text}}</text>

        <view class="images" wx:if="{{item.images && item.images.length > 0}}">
          <image class="img" src="{{img}}" mode="aspectFill" wx:for="{{item.images}}" wx:key="*this"></image>
        </view>

        <view class="actions-bar">
          <view class="action-btn" bindtap="likePost" data-id="{{item.id}}">
            <text>{{item.liked ? '已赞' : '点赞'}}</text>
            <text>{{item.likeCount || 0}}</text>
          </view>
          <view class="action-btn" bindtap="showComment" data-id="{{item.id}}">
            <text>评论 {{item.commentCount || 0}}</text>
          </view>
        </view>

        <view class="comments-section" wx:if="{{item.comments && item.comments.length > 0}}">
          <view class="comment-row" wx:for="{{item.comments}}" wx:for-index="idx" wx:for-item="c" wx:key="idx" wx:if="{{idx < 5 || item.showAllComments}}">
            <text class="comment-user">{{c.name}}:</text>
            <text class="comment-text">{{c.content}}</text>
          </view>
          <view class="show-more" wx:if="{{item.comments.length > 5}}" bindtap="toggleComments" data-id="{{item.id}}">
            {{item.showAllComments ? '收起' : '展开更多'}}
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-mask" bindtap="hidePostModal"></view>
    <view class="modal-content">
      <view class="modal-header">发布动态</view>
      <textarea class="post-input" placeholder="分享一下今天的生活..." bindinput="onPostInput" value="{{postText}}"></textarea>
      <view class="modal-actions">
        <button bindtap="hidePostModal">取消</button>
        <button class="submit" bindtap="submitPost">发布</button>
      </view>
    </view>
  </view>
</view>