.page {
  min-height: 100vh;
  background: #f3f5f8;
  position: relative;
}

.filter-bar {
  display: flex;
  background: #fff;
  padding: 18rpx 24rpx;
  gap: 18rpx;
  margin: 20rpx;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(19, 33, 68, 0.06);
}

.filter-item {
  font-size: 26rpx;
  color: #5b6783;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.filter-item.active {
  background: #ff6b6b;
  color: #fff;
}

.fab {
  position: fixed;
  right: 24rpx;
  top: 170rpx;
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 90rpx;
  font-size: 52rpx;
  z-index: 100;
  box-shadow: 0 10rpx 22rpx rgba(255, 107, 107, 0.35);
}

.feed-list {
  height: calc(100vh - 150rpx);
  padding: 0 20rpx 20rpx;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

.post-item {
  display: flex;
  background: #fff;
  padding: 24rpx;
  border-radius: 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(19, 33, 68, 0.06);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.content {
  flex: 1;
}

.name-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2a44;
}

.city {
  margin-left: 10rpx;
  font-size: 22rpx;
  color: #42507a;
}

.time {
  font-size: 22rpx;
  color: #999;
}

.text {
  display: block;
  margin: 14rpx 0;
  font-size: 28rpx;
}

.images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
}

.actions-bar {
  display: flex;
  gap: 32rpx;
  margin-top: 12rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #eef2f7;
}

.action-btn {
  color: #5b6783;
  font-size: 25rpx;
  display: flex;
  gap: 8rpx;
}

.comments-section {
  margin-top: 10rpx;
  background: #f7f9ff;
  border-radius: 10rpx;
  padding: 12rpx;
}

.comment-row {
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.comment-user {
  color: #4a90e2;
  margin-right: 6rpx;
}

.comment-text {
  color: #333;
}

.show-more {
  color: #4a90e2;
  font-size: 24rpx;
}

.modal {
  position: fixed;
  inset: 0;
  z-index: 200;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 26rpx;
}

.modal-header {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.post-input {
  margin-top: 20rpx;
  border: 1rpx solid #e9eef7;
  border-radius: 12rpx;
  height: 180rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.modal-actions button {
  flex: 1;
  border-radius: 38rpx;
}

.submit {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  color: #fff;
}
