.page {
  min-height: 100vh;
  background: #f3f5f8;
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(19, 33, 68, 0.06);
}

.avatar-card {
  padding: 20rpx;
  text-align: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
}

.avatar-tip {
  display: block;
  margin-top: 10rpx;
  color: #7f8aa3;
  font-size: 22rpx;
}

.form-card {
  margin-top: 16rpx;
  padding: 0 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eff2f7;
}

.no-border {
  border-bottom: none;
}

.textarea-item {
  align-items: flex-start;
}

.label {
  width: 120rpx;
  color: #5b6783;
  font-size: 27rpx;
}

.input,
.picker {
  flex: 1;
  font-size: 28rpx;
  color: #1f2a44;
}

.textarea {
  flex: 1;
  height: 140rpx;
  font-size: 28rpx;
}

.save-btn {
  margin-top: 22rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  color: #fff;
  border-radius: 42rpx;
}
