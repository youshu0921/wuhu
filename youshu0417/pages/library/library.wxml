<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索恋爱知识" bindinput="onInput" value="{{keyword}}" />
  </view>

  <view class="list">
    <view class="item" wx:for="{{filtered}}" wx:key="id" bindtap="openArticle" data-id="{{item.id}}">
      <view class="title">{{item.title}}</view>
      <view class="category">{{item.category}}</view>
      <view class="summary">{{item.summary}}</view>
    </view>

    <view class="empty" wx:if="{{filtered.length === 0}}">没有搜索到内容</view>
  </view>
</view>