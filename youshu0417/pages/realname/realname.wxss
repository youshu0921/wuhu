.page {
  min-height: 100vh;
  background: #f3f5f8;
  padding: 22rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(19, 33, 68, 0.06);
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2a44;
}

.status {
  font-size: 24rpx;
  border-radius: 20rpx;
  padding: 6rpx 14rpx;
}

.status.ok {
  color: #1a8f4f;
  background: #e8f8ef;
}

.status.pending {
  color: #8a6f1b;
  background: #fff8e5;
}

.verified-box {
  margin-top: 16rpx;
  background: #f7f9ff;
  border-radius: 14rpx;
  padding: 16rpx;
}

.verified-text,
.verified-time {
  display: block;
  color: #4c5875;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.form-item {
  margin-top: 18rpx;
  border-bottom: 1rpx solid #eff2f7;
  padding-bottom: 14rpx;
}

.no-border {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #6f7a91;
}

.input {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #1f2a44;
}

.submit-btn {
  margin-top: 20rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  color: #fff;
}

.tips {
  margin-top: 20rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2a44;
}

.tips-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6f7a91;
}
