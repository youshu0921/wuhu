<view class="page">
  <view class="card">
    <view class="title-row">
      <text class="title">实名认证</text>
      <text class="status {{verified ? 'ok' : 'pending'}}">{{verified ? '已认证' : '未认证'}}</text>
    </view>

    <view wx:if="{{verified}}" class="verified-box">
      <text class="verified-text">姓名：{{realName}}</text>
      <text class="verified-text">证件：{{idCardMasked}}</text>
      <text class="verified-time">认证时间：{{verifyTime}}</text>
    </view>

    <view class="form-item">
      <text class="label">真实姓名</text>
      <input class="input" placeholder="请输入真实姓名" value="{{realName}}" bindinput="onNameInput" />
    </view>

    <view class="form-item no-border">
      <text class="label">身份证号</text>
      <input class="input" placeholder="请输入身份证号" value="{{idCard}}" bindinput="onIdCardInput" />
    </view>

    <button class="submit-btn" bindtap="submitVerify" loading="{{submitting}}">
      {{verified ? '重新认证' : '提交认证'}}
    </button>
  </view>

  <view class="tips card">
    <text class="tips-title">温馨提示</text>
    <text class="tips-text">1. 请填写本人真实姓名与身份证号。</text>
    <text class="tips-text">2. 认证信息仅用于实名认证，不会在前台直接展示完整证件号。</text>
  </view>
</view>
