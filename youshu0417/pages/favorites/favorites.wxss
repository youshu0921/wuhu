.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f3f5f8;
}

.empty {
  margin-top: 220rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  color: #333;
}

.empty-sub {
  display: block;
  margin-top: 12rpx;
  color: #999;
  font-size: 24rpx;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(19, 33, 68, 0.06);
}

.main {
  display: flex;
  gap: 18rpx;
}

.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 12rpx;
}

.meta {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.city {
  font-size: 22rpx;
  color: #42507a;
  background: #edf2ff;
  border-radius: 14rpx;
  padding: 4rpx 12rpx;
}

.intro {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
}

.time {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #999;
}

.remove-btn {
  margin-top: 14rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #445173;
  background: #e5eaf5;
}
