<view class="page">
  <view wx:if="{{!favorites.length}}" class="empty">
    <text class="empty-title">还没有收藏对象</text>
    <text class="empty-sub">去首页多认识一些人吧</text>
  </view>

  <view wx:for="{{favorites}}" wx:key="id" class="card">
    <view class="main" data-id="{{item.id}}" bindtap="goDetail">
      <image class="avatar" src="{{item.avatar}}" mode="aspectFill"></image>
      <view class="meta">
        <view class="name-row">
          <text class="name">{{item.nickname}}</text>
          <text class="city">{{item.city || '未知城市'}}</text>
        </view>
        <text class="intro">{{item.intro || '这个人有点低调，还没有填写介绍。'}}</text>
        <text class="time">收藏于：{{item.favoriteTime || '刚刚'}}</text>
      </view>
    </view>
    <button class="remove-btn" data-id="{{item.id}}" bindtap="removeFavorite">取消收藏</button>
  </view>
</view>