.page {
  min-height: 100vh;
  background: #f3f5f8;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx;
}

.empty-icon {
  font-size: 56rpx;
  margin-bottom: 20rpx;
  color: #666;
}

.empty text {
  color: #999;
}

.hint {
  font-size: 24rpx;
  margin-top: 10rpx;
}

.msg-list {
  padding: 20rpx;
}

.msg-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-radius: 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(19, 33, 68, 0.06);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.content {
  flex: 1;
}

.top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
}

.time {
  font-size: 22rpx;
  color: #999;
}

.last-msg {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  background: #ff6b6b;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
}
