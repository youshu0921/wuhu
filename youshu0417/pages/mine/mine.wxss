.page {
  background: #f3f5f8;
  min-height: 100vh;
  padding: 22rpx;
}

.header-card,
.summary-card,
.menu-list {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(19, 33, 68, 0.06);
}

.header-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  margin-right: 18rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  color: #1f2a44;
  font-size: 32rpx;
  font-weight: 600;
}

.id,
.stats {
  color: #6f7a91;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.edit-btn {
  margin: 0;
  min-width: 150rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  background: #edf2ff;
  color: #42507a;
  padding: 0 20rpx;
}

.summary-card {
  margin-top: 18rpx;
  padding: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2a44;
}

.summary-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.summary-item {
  background: #f7f9ff;
  border-radius: 14rpx;
  padding: 14rpx;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #7f8aa3;
}

.summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #2d3a59;
}

.menu-list {
  margin-top: 18rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eff2f7;
}

.menu-item:last-child {
  border-bottom: none;
}

.label {
  flex: 1;
  color: #2d3a59;
  font-size: 28rpx;
}

.arrow {
  color: #a4afc4;
  font-size: 28rpx;
}

.status-badge {
  margin-right: 10rpx;
  font-size: 22rpx;
  border-radius: 16rpx;
  padding: 4rpx 12rpx;
}

.status-badge.ok {
  color: #1a8f4f;
  background: #e8f8ef;
}

.status-badge.pending {
  color: #8a6f1b;
  background: #fff8e5;
}

.calendar-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.calendar-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 30rpx 24rpx 40rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 600;
}

.calendar-close {
  color: #999;
  font-size: 26rpx;
}

.calendar-summary {
  margin-top: 16rpx;
  color: #666;
  font-size: 24rpx;
}

.calendar-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
}

.calendar-day {
  height: 74rpx;
  border-radius: 14rpx;
  background: #f7f7f7;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-num {
  font-size: 24rpx;
  color: #333;
}

.checked-mark {
  position: absolute;
  right: 6rpx;
  bottom: 2rpx;
  color: #2dc36a;
  font-size: 24rpx;
  font-weight: 700;
}

.calendar-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #999;
}
